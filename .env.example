# API Externa (Proveexpress)
API_BASE_URL=https://api.example.com
API_USERNAME=usuario_api
API_PASSWORD=tu_password_aqui

# SharePoint (para subir CSVs)
# Requiere App Registration en Azure AD.
AZURE_TENANT_ID=tu-tenant-id
AZURE_CLIENT_ID=tu-client-id
AZURE_CLIENT_SECRET=tu-client-secret

# Recomendado si el destino es una carpeta compartida de SharePoint/OneDrive.
SHAREPOINT_FOLDER_URL=https://tuorganizacion.sharepoint.com/:f:/g/ruta-carpeta-compartida

# Alternativas para localizar sitio/drive si no usas SHAREPOINT_FOLDER_URL:
SHAREPOINT_SITE_URL=https://tuorganizacion.sharepoint.com/sites/TuSitio
# SHAREPOINT_SITE_ID=tenant.sharepoint.com,site-guid,web-guid
# SHAREPOINT_SITE=nombre-del-sitio-o-hostname
# SHAREPOINT_DRIVE_ID=drive-id-especifico

# Opcional:
# - Con SHAREPOINT_FOLDER_URL, se ignora porque la URL ya es la carpeta destino.
# - Sin SHAREPOINT_FOLDER_URL, usa esta ruta dentro del drive.
SHAREPOINT_FOLDER=
